---
import { oneArtiste, scenesByArtisteId, oneScene } from "../../../backend/backend.mjs";
import Layout from "../../layouts/Layout.astro";
import PbImage from "../../components/PbImage.astro";

const {id} = Astro.params;
const scenes = await oneArtiste(id);

const sceneNom = await oneScene(id);
---

<Layout titre={artiste.Nom}>
    <h1>{artiste.Nom}</h1>
    <div class="grille pb-16">
        <div class="lg:col-start-2 lg:col-end-7">
            <PbImage
                record={artiste}
                recordImage={artiste.Photo}
                width={900}
                height={700}
                MyClass="h-auto w-full rounded-[7px] object-cover"
            />
        </div>
        <div class="mt-6 space-y-4 lg:col-start-7 lg:col-end-12 lg:mt-0">
            <p>{scenes.Nom}</p>
            <p>{artiste.Description}</p>
        </div>
    </div>
</Layout>
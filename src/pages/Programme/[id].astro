---
import { oneArtiste, scenesByArtisteId, formatDate, getImageUrl } from "../../../backend/backend.mjs";
import Layout from "../../layouts/Layout.astro";
import PbImage from "../../components/PbImage.astro";

const {id} = Astro.params;
const artiste = await oneArtiste(id);
const scenes = await scenesByArtisteId(id);
const galleryFiles = Array.isArray(artiste.Photos_gallery) ? artiste.Photos_gallery : [];
const galleryImages = await Promise.all(
    galleryFiles.map(async (fileName) => ({
        fileName,
        url: await getImageUrl(artiste, fileName),
    }))
);
---

<Layout titre={artiste.Nom}>
    <h1>{artiste.Nom}</h1>
    <div class="grille pb-16">
        <div class="lg:col-start-2 lg:col-end-7">
            <PbImage
                record={artiste}
                recordImage={artiste.Photo}
                width={900}
                height={700}
                MyClass="h-auto w-full rounded-[7px] object-cover"
            />
        </div>
        <div class="mt-6 space-y-4 lg:col-start-7 lg:col-end-12 lg:mt-0">
            {
                scenes.map((scene) => (
                    <p>{scene.Nom}</p>
                ))
            }
            <p>{formatDate(artiste.Date_heure_production)}</p>
            <p>{artiste.Description}</p>
        </div>
    </div>

    {
        galleryImages.length > 0 && (
            <div class="grille pb-16">
                <h2 class="lg:col-start-2 lg:col-end-12 mb-4">Galerie</h2>
                <div class="lg:col-start-2 lg:col-end-12 grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
                    {
                        galleryImages.map((image) => (
                            <img
                                src={image.url}
                                alt={`Galerie ${artiste.Nom}`}
                                class="h-56 w-full rounded-[7px] object-cover"
                                loading="lazy"
                            />
                        ))
                    }
                </div>
            </div>
        )
    }
</Layout>
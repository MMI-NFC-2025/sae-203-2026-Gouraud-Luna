---
import Layout from "../../layouts/Layout.astro";
import { SceneSortedByName } from "../../../backend/backend.mjs";
import SceneCard from "../../components/SceneCard.astro";
const scene = await SceneSortedByName();
---

<Layout>
    <div>
        <h1>Scènes</h1>
        <div class="grille">
            <div class="lg:col-start-2 lg:col-end-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3 mt-10 mb-30">
                {
                    scene.map((artiste) => (
                        <SceneCard artiste={artiste} />
                    ))
                }
            </div>
    </div>
</Layout>